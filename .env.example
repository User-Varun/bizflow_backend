# Copy values into .env.development for local run
# Use your hosting provider env dashboard for production secrets
PORT=8080
SUPABASE_CONNECTION_STRING=postgresql://postgres.example:[YOUR-DB-PASSWORD]@host:5432/postgres
SUPABASE_PASSWORD=YOUR-DB-PASSWORD
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=90d
CORS_ORIGINS=http://localhost:5173
